MANUAL_KEYWORD=

RAILWAY_API_BASE_URL=https://sourcing-production-8102.up.railway.app
CRAWLER_KEYWORDS_ENDPOINT=/api/admin/keyword-sourcing/crawler-keywords
CRAWLER_KEYWORDS_LIMIT=10
# UI 테이블·미리보기: Admin final keywords 최대 조회 수 (배치 실행 limit 과 별도)
CRAWLER_KEYWORDS_DISPLAY_LIMIT=10000
CRAWLER_RUN_ID=
CRAWLER_DATE_VALUE=
MYSQL_URL=
MYSQL_PUBLIC_URL=
MARIADB_PUBLIC_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

COUPANG_HEADLESS=false
COUPANG_SMOKE_HEADLESS=false
# smoke SERP 후 상세 클릭·판매량 (0=끔)
COUPANG_SMOKE_RANK1_DETAIL=1
# 1~10위 중 리뷰 상위 N개만 상세 탭·결과 테이블 (기본 5)
COUPANG_SMOKE_DETAIL_LIMIT=5
# 상세 판매량 수집 속도 (기본 fast=1: domcontentloaded·짧은 재시도)
COUPANG_SMOKE_DETAIL_FAST=1
COUPANG_SMOKE_DETAIL_GOTO_WAIT=domcontentloaded
COUPANG_SMOKE_DETAIL_GOTO_TIMEOUT_MS=22000
COUPANG_SMOKE_DETAIL_PARSE_ATTEMPTS=2
COUPANG_SMOKE_DETAIL_BADGE_WAIT_MS=2800
COUPANG_SMOKE_DETAIL_RETRY_WAIT_MS=350
# networkidle 대기 (느리지만 배지 늦게 뜨는 경우만 1)
COUPANG_SMOKE_DETAIL_NETWORK_IDLE=0
# 상세 HTML/PNG 디버그: off | miss | all
COUPANG_SMOKE_DEBUG_DETAIL=miss
COUPANG_SMOKE_GOOGLE_QUERY=쿠팡
COUPANG_SMOKE_COUPANG_QUERY=
COUPANG_SMOKE_STORAGE_STATE=.smoke/coupang_state.json
COUPANG_SMOKE_SUBPROCESS=0
COUPANG_SMOKE_EXTRACT_DB=false
COUPANG_PLAYWRIGHT_CHANNEL=

BRIGHTDATA_API_TOKEN=
BRIGHTDATA_REQUEST_ZONE=
COUPANG_BRIGHT_REQUEST=off
COUPANG_BRIGHT_MIN_ITEMS=7
BRIGHTDATA_REQUEST_TIMEOUT_SEC=35
BRIGHTDATA_REQUEST_RETRIES=1
BRIGHTDATA_BROWSER_WS_1688=
CHINA_1688_BROWSER_COUNTRY=KR
CHINA_SEARCH_TOP_N=8
CHINA_FX_CNY_TO_KRW=185
CHINA_SEARCH_SLEEP_SEC=3

# Gemini 트렌드 마켓 스코어 (Google Search Grounding)
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=
GEMINI_TREND_MODEL=gemini-2.5-flash
GEMINI_TREND_AUTO_ON_CRAWL=true
GEMINI_TREND_REFERENCE_MONTH=2026년 5월
