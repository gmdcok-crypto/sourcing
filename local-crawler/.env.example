COUPANG_SMOKE_HEADLESS=false
# smoke SERP 후 상세 클릭·판매량 (0=끔)
COUPANG_SMOKE_RANK1_DETAIL=1
# 상세 진입 순위 수 (1~10). SERP 유지 + 상세만 새 탭에서 열고 닫기
