COUPANG_SMOKE_SUBPROCESS=0
COUPANG_SMOKE_EXTRACT_DB=false
COUPANG_PLAYWRIGHT_CHANNEL=

BRIGHTDATA_API_TOKEN=
BRIGHTDATA_REQUEST_ZONE=
COUPANG_BRIGHT_REQUEST=off
COUPANG_BRIGHT_MIN_ITEMS=7
BRIGHTDATA_REQUEST_TIMEOUT_SEC=35
BRIGHTDATA_REQUEST_RETRIES=1
BRIGHTDATA_BROWSER_WS_1688=
